[app]

# 应用名称
title = 接星星

# 包名
package.name = starcatcher

# 包域名
package.domain = org.arona

# 源码文件
source.dir = .
source.include_exts = py,png,jpg,kv,atlas

# 版本
version = 1.1.0

# 需求
requirements = python3,kivy

# 权限
android.permissions = INTERNET

# 图标
# icon = icon.png

# 启动画面
# presplash = splash.png

# 屏幕方向
orientation = portrait

# 全屏
fullscreen = 1

# 最低SDK版本
android.minapi = 21

# 目标SDK版本
android.api = 33

# NDK版本
android.ndk = 25b

# 编译模式
android.build_mode = debug

# 架构
android.archs = arm64-v8a

# 是否使用默认gradle
# android.gradle_dependencies = []

[buildozer]

# 日志级别
log_level = 2

# 编译目录
warn_on_root = 1

# 使用Android SDK路径
# android.sdk_path = 
# android.ndk_path = 
# android.ant_path =
